package "Property Management" #FFF3E0 {
  
  class properties <<PK>> {
    * id : UUID <<PK>>
    --
    code : TEXT <<UNIQUE>>
    old_code : TEXT
    * title_ar : TEXT
    * title_en : TEXT
    description_ar : TEXT
    description_en : TEXT
    address_ar : TEXT
    address_en : TEXT
    governorate_id : UUID <<FK>>
    area_id : UUID <<FK>>
    street_id : UUID <<FK>>
    location_text : TEXT
    latitude : DECIMAL(10,8)
    longitude : DECIMAL(11,8)
    owner_id : UUID <<FK>>
    section_id : UUID <<FK>>
    property_type_id : UUID <<FK>>
    price : DECIMAL(15,2)
    payment_method_id : UUID <<FK>>
    size : DECIMAL(10,2)
    baths : INTEGER
    floor_no : INTEGER
    view_type_id : UUID <<FK>>
    finishing_type_id : UUID <<FK>>
    phone_number : TEXT
    * status : TEXT {pending, active, inactive, rejected, deleted, expired, rented, sold}
    * is_featured : BOOLEAN
    * is_rented : BOOLEAN
    * is_sold : BOOLEAN
    created_by : UUID <<FK>>
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
    expired_at : TIMESTAMPTZ
  }
  
  class property_owners <<PK>> {
    * id : UUID <<PK>>
    --
    * name : TEXT
    * phone_number : TEXT
    email : TEXT <<UNIQUE>>
    password_hash : TEXT
    * status : TEXT {active, inactive, suspended}
    last_login_at : TIMESTAMPTZ
    * login_count : INTEGER
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class property_images <<PK>> {
    * id : UUID <<PK>>
    --
    * property_id : UUID <<FK>>
    * image_url : TEXT
    alt_text_ar : TEXT
    alt_text_en : TEXT
    * order_index : INTEGER
    * is_primary : BOOLEAN
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class property_bookings <<PK>> {
    * id : UUID <<PK>>
    --
    * property_id : UUID <<FK>>
    * customer_name : TEXT
    * customer_email : TEXT
    * customer_phone : TEXT
    * booking_from_date : DATE
    * booking_to_date : DATE
    * total_price : DECIMAL(15,2)
    * status : TEXT {pending, confirmed, cancelled, completed}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class property_comments <<PK>> {
    * id : UUID <<PK>>
    --
    * property_id : UUID <<FK>>
    user_id : UUID <<FK>>
    * name : TEXT
    email : TEXT
    * comment_text : TEXT
    * status : TEXT {pending, approved, rejected}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class featured_areas <<PK>> {
    * id : UUID <<PK>>
    --
    * governorate_id : UUID <<FK>>
    * area_id : UUID <<FK>>
    projects_order : JSONB
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
}

