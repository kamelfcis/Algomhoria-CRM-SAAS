@startuml Database Schema - News Website + Real Estate Management

!define NEWS_COLOR #E3F2FD
!define PROPERTY_COLOR #FFF3E0
!define MASTER_COLOR #F3E5F5
!define SYSTEM_COLOR #E8F5E9
!define RELATION_COLOR #424242

skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam class {
    BackgroundColor<<PK>> #FFE082
    BackgroundColor<<FK>> #C5E1A5
    BackgroundColor<<UNIQUE>> #B39DDB
    ArrowColor #424242
    BorderColor #424242
}

title Database Schema - News Website + Real Estate Management\n<size:12><b>Complete Schema with 32+ Tables</b></size>

' ============================================================================
' NEWS/BLOG SECTION
' ============================================================================

package "News & Blog Management" #E3F2FD {
  
  class users <<PK>> {
    * id : UUID <<PK>>
    --
    * email : TEXT <<UNIQUE>>
    * password_hash : TEXT
    * name : TEXT
    phone_number : TEXT
    * role : TEXT {admin, moderator, sales, user}
    author_image_url : TEXT
    * status : TEXT {active, inactive, suspended}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class team_users <<PK>> {
    * id : UUID <<PK>>
    --
    * name : TEXT
    name_ar : TEXT
    * position : TEXT
    poition_ar : TEXT
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class categories <<PK>> {
    * id : UUID <<PK>>
    --
    * title_ar : TEXT
    * title_en : TEXT
    meta_title_ar : TEXT
    meta_title_en : TEXT
    meta_description_ar : TEXT
    meta_description_en : TEXT
    meta_keywords_ar : TEXT
    meta_keywords_en : TEXT
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class posts <<PK>> {
    * id : UUID <<PK>>
    --
    * title_ar : TEXT
    * title_en : TEXT
    excerpt_ar : TEXT
    excerpt_en : TEXT
    * content_ar : TEXT
    * content_en : TEXT
    meta_title_ar : TEXT
    meta_title_en : TEXT
    meta_description_ar : TEXT
    meta_description_en : TEXT
    meta_keywords_ar : TEXT
    meta_keywords_en : TEXT
    category_id : UUID <<FK>>
    author_id : UUID <<FK>>
    thumbnail_url : TEXT
    cover_url : TEXT
    * is_breaking_news : BOOLEAN
    * is_featured : BOOLEAN
    * status : TEXT {draft, pending, active, inactive}
    published_at : TIMESTAMPTZ
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class post_gallery <<PK>> {
    * id : UUID <<PK>>
    --
    * post_id : UUID <<FK>>
    * image_url : TEXT
    alt_text_ar : TEXT
    alt_text_en : TEXT
    * order_index : INTEGER
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class sliders <<PK>> {
    * id : UUID <<PK>>
    --
    title_ar : TEXT
    title_en : TEXT
    description_ar : TEXT
    description_en : TEXT
    * image_url : TEXT
    link_url : TEXT
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class newsletter_subscribers <<PK>> {
    * id : UUID <<PK>>
    --
    * email : TEXT <<UNIQUE>>
    name : TEXT
    * status : TEXT {active, unsubscribed}
    * subscribed_at : TIMESTAMPTZ
    unsubscribed_at : TIMESTAMPTZ
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class leads <<PK>> {
    * id : UUID <<PK>>
    --
    * type : TEXT {message, inquiry, complaint}
    * name : TEXT
    * phone_number : TEXT
    email : TEXT
    * message : TEXT
    entity_type : TEXT
    entity_id : UUID
    entity_title : TEXT
    created_by : UUID <<FK>>
    assigned_to : UUID <<FK>>
    * status : TEXT {new, handled, archived}
    * priority : TEXT {low, normal, high, urgent}
    notes : TEXT
    property_owner_id : UUID <<FK>>
    handled_at : TIMESTAMPTZ
    contacted_at : TIMESTAMPTZ
    converted_at : TIMESTAMPTZ
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class direct_leads <<PK>> {
    * id : UUID <<PK>>
    --
    * name : TEXT
    * phone_number : TEXT
    email : TEXT
    message : TEXT
    source : TEXT
    property_owner_id : UUID <<FK>>
    assigned_to : UUID <<FK>>
    * status : TEXT {new, contacted, qualified, converted, lost, archived}
    * priority : TEXT {low, normal, high, urgent}
    notes : TEXT
    created_by : UUID <<FK>>
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
    contacted_at : TIMESTAMPTZ
    converted_at : TIMESTAMPTZ
  }
  
  class leads_assignments <<PK>> {
    * id : UUID <<PK>>
    --
    lead_id : UUID <<FK>>
    direct_lead_id : UUID <<FK>>
    * assigned_to : UUID <<FK>>
    assigned_by : UUID <<FK>>
    * status : TEXT {active, completed, cancelled}
    notes : TEXT
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
    completed_at : TIMESTAMPTZ
  }
  
  class settings <<PK>> {
    * id : UUID <<PK>>
    --
    * key : TEXT <<UNIQUE>>
    value : TEXT
    value_json : JSONB
    description : TEXT
    logo_url : TEXT
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class projects <<PK>> {
    * id : UUID <<PK>>
    --
    * title_ar : TEXT
    * title_en : TEXT
    description_ar : TEXT
    description_en : TEXT
    image_url : TEXT
    category_id : UUID <<FK>>
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
  
  class project_categories <<PK>> {
    * id : UUID <<PK>>
    --
    * title_ar : TEXT
    * title_en : TEXT
    image_url : TEXT
    * order_index : INTEGER
    * status : TEXT {active, inactive}
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
  }
}

' ============================================================================
' PROPERTY MANAGEMENT SECTION
